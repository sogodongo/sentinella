# Sentinella environment configuration
# Copy to .env.local for local overrides — never commit .env.local

SENTINELLA_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://sentinella:sentinella_dev@localhost:5432/sentinella

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# MinIO / Object Store
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=sentinella
MINIO_SECRET_KEY=sentinella_dev

# OPA
OPA_URL=http://localhost:8181

# Service URLs (for local development without docker-compose)
POLICY_SERVICE_URL=http://localhost:8081
LEDGER_SERVICE_URL=http://localhost:8082
EVALS_SERVICE_URL=http://localhost:8083
AIBOM_SERVICE_URL=http://localhost:8084

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=sentinella-local
